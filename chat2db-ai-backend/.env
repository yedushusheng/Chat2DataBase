# ==========================================
# Chat2DB-AI 企业级多数据库智能问答系统
# 开发环境配置
# ==========================================

# --- 应用基础 ---
APP_NAME=Chat2DB-AI
APP_VERSION=1.0.0
ENV=development
DEBUG=true
HOST=0.0.0.0
PORT=8000
WORKERS=1

# --- CORS ---
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://localhost:3000"]

# --- 日志 ---
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_DIR=./logs

# --- RAG / Chroma ---
CHROMA_PERSIST_DIR=./chroma_db
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHROMA_COLLECTION=db_knowledge

# --- 自研数据库标识 ---
SELF_DB_NAME=SelfDB
SELF_DB_IDENTIFIERS=["自研","selfdb","公司数据库","内部数据库"," proprietary"]

# --- 外部模型API密钥 ---
# 豆包 (Volcengine)
DOUBAO_API_KEY=your-doubao-api-key
DOUBAO_MODEL=ep-2025xxxxxxxxx
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 文心一言 (Baidu)
WENXIN_API_KEY=your-wenxin-api-key
WENXIN_SECRET_KEY=your-wenxin-secret-key
WENXIN_MODEL=ernie-bot-4

# DeepSeek
DEEPSEEK_API_KEY=sk-1MBdvR2rDvLSqsJFEjdbRD57qZxpMUEwsIhZigdwKVu31PVM
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# OpenAI / ChatGPT (兼容格式，若使用第三方中转请修改 BASE_URL)
OPENAI_API_KEY=sk-1MBdvR2rDvLSqsJFEjdbRD57qZxpMUEwsIhZigdwKVu31PVM
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1

# Claude (自研数据库专用深度推理)
CLAUDE_API_KEY=your-claude-api-key
CLAUDE_MODEL=claude-opus-4-7
CLAUDE_BASE_URL=https://api.anthropic.com/v1

# --- 路由策略 ---
ROUTER_STRATEGY=priority
EXTERNAL_MODEL_PRIORITY=["deepseek","doubao","wenxin","openai"]
FALLBACK_ENABLED=true

# --- 上传配置 ---
MAX_UPLOAD_SIZE=52428800
ALLOWED_EXTENSIONS=["pdf","docx","txt","md"]
UPLOAD_DIR=./uploads

# --- 对话持久化 ---
CONVERSATION_STORE=sqlite
CONVERSATION_DB_PATH=./conversations.db

# --- SQL校验 ---
SQL_CHECK_ENABLED=true
SQL_DANGEROUS_KEYWORDS=["drop","delete","truncate","shutdown","kill","rm -rf"]
